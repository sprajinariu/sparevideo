CAPI=2:
name: "opensoc:video:sparesoc_top"
description: "Sparesoc top-level — video passthrough pipeline"

filesets:
  files_rtl:
    files:
      - hw/top/sparesoc_top.sv
    file_type: systemVerilogSource

  files_lint:
    files:
      - hw/lint/verilator_waiver.vlt: {file_type: vlt}

targets:
  default:
    filesets:
      - files_rtl
    toplevel: sparesoc_top

  lint:
    filesets:
      - files_rtl
      - files_lint
    toplevel: sparesoc_top
    default_tool: verilator
    tools:
      verilator:
        mode: lint-only
        verilator_options:
          - "-Wall"
